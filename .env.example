# ── Database ──────────────────────────────────────────
DB_NAME=devticket
DB_USER=devticket
DB_PASSWORD=여기에_강력한_비밀번호_입력

# ── Auth ──────────────────────────────────────────────
# 아래 명령으로 생성: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=여기에_32바이트_랜덤_시크릿_입력

# ── CORS (배포 시 실제 도메인으로 변경) ────────────────
CORS_ORIGINS=http://localhost:8080
